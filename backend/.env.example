# Backend Configuration
#
# Copy this file to .env and adjust values for your environment.

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/restofnb?sslmode=disable

# JWT signing secret (change in production!)
JWT_SECRET=dev-secret-change-in-production

# HTTP server listen address
ADDR=:8080

# Run database seed on startup ("true" to enable)
SEED_ON_START=true

# QR code frontend base URL
QR_FRONTEND_URL=http://localhost:3000
